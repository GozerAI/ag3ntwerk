# ag3ntwerk VPS Environment Configuration
# =======================================
# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# --- Required ---
PG_PASSWORD=change-me-to-a-strong-password
REDIS_PASSWORD=change-me-to-a-strong-password
AGENTWERK_SECRETS_KEY=change-me-to-a-random-32-char-string

# --- Database ---
PG_DATABASE=ag3ntwerk
PG_USER=ag3ntwerk
DATABASE_BACKEND=postgresql

# --- Auth ---
AGENTWERK_AUTH_REQUIRED=true

# --- LLM Providers (at least one recommended) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# For local LLM (if running Ollama on the VPS):
# OLLAMA_HOST=http://ollama:11434

# --- Version ---
AGENTWERK_VERSION=latest
