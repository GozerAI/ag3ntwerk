# ag3ntwerk Environment Variables
# ==============================
# Copy this file to .env and fill in values as needed.
# Variables with defaults are optional for local development.

# ── Infrastructure ──────────────────────────────────────────────────
PG_PASSWORD=csuite_dev_password
REDIS_PASSWORD=csuite_dev_redis

# ── Monitoring (optional) ──────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── Social Integrations (optional) ─────────────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ── Payment Integrations (optional) ────────────────────────────────
GUMROAD_ACCESS_TOKEN=

# ── Voice (optional) ───────────────────────────────────────────────
# auto | whisper | openai
WHISPER_BACKEND=auto
